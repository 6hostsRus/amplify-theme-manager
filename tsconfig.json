{
     "compilerOptions": {
          "target": "ES2020",
          "lib": ["ES2020", "DOM", "DOM.Iterable"],
          "module": "ESNext",
          "jsx": "react-jsx",
          "declaration": true,
          "declarationMap": false,
          "sourceMap": true,
          "moduleResolution": "Bundler",
          "skipLibCheck": true,
          "esModuleInterop": true,
          "forceConsistentCasingInFileNames": true,
          "strict": true,
          "resolveJsonModule": true,
          "baseUrl": ".",
          "outDir": "dist"
     },
     "include": ["src", "example", "vite.config.ts"]
}
