{
  "name": "@your-scope/amplify-theme-manager",
  "version": "0.2.0",
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./dev/*": {
      "import": "./dist/dev/*.js",
      "types": "./dist/dev/*.d.ts"
    },
    "./icons/*": {
      "import": "./dist/icons/*.js",
      "types": "./dist/icons/*.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist",
    "example": "vite example",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@aws-amplify/ui-react": ">=5.0.0",
    "react": ">=18",
    "react-dom": ">=18",
    "react-icons": "^5.5.0"
  },
  "peerDependenciesMeta": {
    "react-icons": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "rimraf": "^5.0.5",
    "tsup": "^8.0.1",
    "typescript": "^5.4.0",
    "vite": "^5.0.0"
  }
}
